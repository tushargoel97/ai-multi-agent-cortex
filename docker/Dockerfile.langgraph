FROM python:3.11-slim

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /app

# Install dependencies first (layer caching)
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-install-project

# Copy the rest of the project
COPY langgraph.json settings.yaml ./
COPY cortex/ cortex/
RUN uv sync --frozen

# langgraph.json references .env but it's excluded via .dockerignore;
# create an empty file so the CLI doesn't error out (real vars come from compose).
RUN touch .env

EXPOSE 2024

# Run Python directly as PID 1 so Docker SIGTERM reaches our SIGTERM handler.
# (uv run would spawn Python as a child process, swallowing the signal,
#  which prevents the in-mem persistence flush from running on shutdown.)
CMD ["/app/.venv/bin/python", "/app/.venv/bin/langgraph", "dev", \
     "--host", "0.0.0.0", "--port", "2024", "--no-browser", "--no-reload", \
     "--config", "langgraph.json"]
