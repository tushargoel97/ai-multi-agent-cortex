# Custom durable LangGraph runtime with Postgres persistence.
FROM python:3.11-slim

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /app

# Install dependencies first (layer caching).
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-install-project

# Copy the project and install it.
COPY langgraph.json settings.yaml README.md ./
COPY cortex/ cortex/
RUN uv sync --frozen

# langgraph.json references .env but it's excluded via .dockerignore; create an
# empty file so tooling doesn't error (real vars come from compose).
RUN touch .env

EXPOSE 8000

# Uvicorn runs the custom FastAPI server. The lifespan sets up the Postgres
# pool, runs checkpointer/store migrations, and compiles the graph before
# serving, so health responds only after persistence is ready.
CMD ["/app/.venv/bin/uvicorn", "cortex.api.app:app", \
     "--host", "0.0.0.0", "--port", "8000"]
