FROM node:20-slim

RUN corepack enable && corepack prepare pnpm@10.5.1 --activate

WORKDIR /app

# Install exactly the dependency graph committed for pnpm. Platform-specific
# optional packages are resolved for Linux during the container build.
COPY agent-chat-ui/package.json agent-chat-ui/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# Copy the rest of the UI source
COPY agent-chat-ui/ .

# Public client settings are compiled into the Next.js bundle. These defaults
# keep the browser on the same-origin API proxy; deployments may override them
# with Docker build args.
ARG NEXT_PUBLIC_API_URL=/api/v1
ARG NEXT_PUBLIC_ASSISTANT_ID=cortex
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_ASSISTANT_ID=${NEXT_PUBLIC_ASSISTANT_ID}

RUN pnpm build

EXPOSE 3000

CMD ["pnpm", "start", "--hostname", "0.0.0.0", "--port", "3000"]
