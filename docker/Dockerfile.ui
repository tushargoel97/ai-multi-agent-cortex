FROM node:20-slim

RUN corepack enable && corepack prepare pnpm@10.5.1 --activate

WORKDIR /app

# Copy package.json only — the macOS lockfile has wrong native bindings
# for Linux; let pnpm resolve the correct platform-specific deps.
COPY agent-chat-ui/package.json ./
RUN pnpm install

# Copy the rest of the UI source
COPY agent-chat-ui/ .

EXPOSE 3000

CMD ["pnpm", "next", "dev", "--hostname", "0.0.0.0", "--port", "3000"]
