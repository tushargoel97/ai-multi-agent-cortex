# ── Identity ─────────────────────────────────────────────────────────────────
ASSISTANT_NAME=Cortex

# ── Admin panel ──────────────────────────────────────────────────────────────
# Token required to access /admin in the chat UI. Pick anything; users enter
# this once in the admin login form (stored in localStorage).
ADMIN_TOKEN=change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ── Fine-tuning trainer (host-side MLX service, see trainer/README.md) ──────
# How the UI container reaches the trainer running on the host.
# TRAINER_URL=http://host.docker.internal:8200

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://cortex:cortex@localhost:5432/cortex

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small

# ── LLM Provider (openai | azure_openai) ─────────────────────────────────────
LLM_PROVIDER=openai

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-5-nano
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://models.github.ai/inference

# ── Azure OpenAI (only needed if LLM_PROVIDER=azure_openai) ─────────────────
# AZURE_OPENAI_MODEL=gpt-4o
# AZURE_OPENAI_TEMPERATURE=0
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── Observability (Langfuse + OpenTelemetry) ─────────────────────────────────
OTEL_SERVICE_NAME=cortex
LANGFUSE_HOST=http://localhost:4000
LANGFUSE_PUBLIC_KEY=pk-lf-local-public
LANGFUSE_SECRET_KEY=sk-lf-local-secret
LANGSMITH_TRACING=true

# ── LangGraph Server license (self-hosted durable persistence) ─────────────
# The self-hosted LangGraph Server validates this key with LangSmith on startup
# (a license check only). The langgraph service in docker-compose.yml forces
# LANGSMITH_TRACING=false, so no run data is sent — the key is used purely for
# license verification. Get a free key at https://smith.langchain.com →
# Settings → API Keys (requires a LangSmith account with Deployments access).
LANGSMITH_API_KEY=lsv2_...